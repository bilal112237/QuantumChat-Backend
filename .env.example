PORT=5000
# Either set a full connection string...
MONGODB_URI=mongodb://localhost:27017/quantumchat
# ...or split Atlas credentials (used when MONGODB_URI is not set)
# MONGODB_USER=your_db_user
# MONGODB_PASSWORD=your_db_password
# MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
# MONGODB_DB=quantumchat
JWT_SECRET=change_this_to_a_long_random_secret
QUANTUM_AI_SERVICE_SECRET=change_this_to_a_second_long_random_shared_secret
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed frontend origins (merged with built-in product URLs).
# 5173 = QuantumChat frontend, 5175 = QuantumAI frontend (local Vite)
# Production must include https://ai.quantumlogicslimited.com for QuantumAI login.
CLIENT_URL=http://localhost:5173,http://localhost:5175,https://chat.quantumlogicslimited.com,https://ai.quantumlogicslimited.com
FRONTEND_URL=http://localhost:5173

EXPOSE_EMAIL_LINKS=1

# Optional real SMTP. When SMTP_HOST, SMTP_USER, and SMTP_PASS are all set,
# sendAppMail uses nodemailer; otherwise emails are logged to the console.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM="QuantumChat <noreply@example.com>"

UPLOAD_DIR=uploads

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
