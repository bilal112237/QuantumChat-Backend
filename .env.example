NODE_ENV=development
PORT=4000
# MongoDB Atlas example (database name after the host):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/quantum-chat?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/quantum-chat
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
ADMIN_EMAIL=admin@quantumchat.io
ADMIN_PASSWORD=Admin123!
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
